;; DEMO: Polish seller → Polish buyer, mixed VAT, no KSeF.
;;
;; The ordinary domestic case. Buyer has a PL :nip, so Podmiot2 emits
;; <NIP>. Items span 23%, 8%, 5%, :zw to exercise bucket routing across
;; P_13_1, P_13_2, P_13_3 and P_13_7.

{:seller {:name "Mr. Blobby Consulting"
          :address "ul. Warszawska 12, 00-001 Warszawa"
          :nip 1234567890
          :account "12 3456 7890 1234 5678 9012 3456"
          :bank "Bank PKO BP"
          :email "mr.blobby@example.com"
          :phone 555123456}
 :font-path "/usr/share/fonts/truetype/freefont/FreeSans.ttf"
 :invoices [{:buyer {:name "Buty S.A."
                     :address "ul. Szewska 32, 76-543 Bakow"
                     :nip 9875645342
                     :email "faktury@buty.example"}
             :currency "PLN"
             :items [{:vat 23 :netto 1200.00M :title "Konsultacje IT"}
                     {:vat 8  :netto 450.00M  :title "Remont biura"}
                     {:vat 5  :netto 200.00M  :title "Materialy biurowe"}
                     {:vat :zw :netto 100.00M :title "Uslugi zwolnione z VAT"
                      :notes ["Podstawa zwolnienia z VAT: art. 113 ust. 1 i 9 Ustawa o VAT"]}]}]}
